{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "schedule": [
    "every weekend"
  ],
  "dependencyDashboard": false,
  "ignoreTests": true,
  "packageRules": [
    {
      "groupName": "dependencies",
      "matchDatasources": [
        "npm"
      ],
      "matchPackageNames": [
        "*"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "matchDatasources": [
        "packagist"
      ],
      "enabled": false
    },
    {
      "groupName": "workflows",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ]
    }
  ]
}